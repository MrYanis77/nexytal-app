PORT=3000
NODE_ENV=development

# MySQL (XAMPP par defaut : utilisateur root, mot de passe vide)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=nexytal_db

# Securite : a remplacer par une chaine aleatoire longue en production
IP_HASH_SALT=nexytal-dev-salt-please-change-this-in-production-environment

# CORS : laisser vide en dev (defaults sur localhost:5173)
CORS_ORIGINS=

# Email : g\u00e9r\u00e9 par PHPMailer dans public/api/config.php (SMTP OVH)
# Fonctionne en local (XAMPP) et sur OVH FTP

# Compte admin par defaut
ADMIN_EMAIL=admin@nexytal.com
ADMIN_PASSWORD=Admin1234!
ADMIN_PRENOM=Admin
ADMIN_NOM=Nexytal
